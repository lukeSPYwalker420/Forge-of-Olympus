    {
      "week": 1,
      "day": 1,
      "focus": "Recognition & Positional Control - Strength (Squat Bias)",
      "exercises": [
        { "liftName": "Box-Constrained Back Squat", "sets": 4, "reps": "6-8", "rpeTarget": 7, "progressionType": "strength", "notes": "Technique bar. Vertical torso priority. Box defines depth. No collapse forward." },
        { "liftName": "Flat Barbell Bench Press (Fixed Load)", "sets": 4, "reps": "6-8", "rpeTarget": 7, "progressionType": "strength", "notes": "Terminate set if hips rise. Rib control priority." },
        { "liftName": "Romanian Deadlift", "sets": 3, "reps": "8-10", "rpeTarget": 7, "progressionType": "strength", "notes": "Maintain neutral spine. Use as hinge reinforcement." },
        { "liftName": "Behind-the-Neck Lat Pulldown (Constrained)", "sets": 3, "reps": "8-10", "rpeTarget": 6, "progressionType": "volume", "notes": "Very light load. Stop before rib flare or head jut. Focus scap depression + ER." },
        { "liftName": "Barbell Side Bends (Back Loaded)", "sets": 3, "reps": "10-12", "stabilityTarget": 7, "painTarget": 4, "progressionType": "mobility", "notes": "Light technique bar. Controlled lateral movement, no collapse." }
      ]
    },
